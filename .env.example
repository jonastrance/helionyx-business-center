# ── Server ──────────────────────────────────────
PORT=3000

# ── PostgreSQL ──────────────────────────────────
# Option A: connection string (preferred)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/helionyx

# Option B: individual vars (used if DATABASE_URL is not set)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=helionyx
# PGUSER=postgres
# PGPASSWORD=yourpassword

# ── AI Providers ────────────────────────────────
# Ollama runs locally — no key needed
# Add keys below to unlock Anthropic, OpenAI, MiniMax in Abbot

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MINIMAX_API_KEY=

# ── WHMCS API (for WHMCS panel) ──
WHMCS_URL=https://helionyxcommons.com/includes/api.php
WHMCS_IDENTIFIER=
WHMCS_SECRET=

# ── WHM API (for Server Health panel) ──
WHM_URL=https://host39.registrar-servers.com:2087
WHM_TOKEN=
